      "parameters": {
        "jsCode": "// Robust extractor for contacted names from GHL search response.\n// Handles multiple possible shapes and adds debug info.\n\nconst contactedNames = new Set();\n\nfunction norm(s) {\n  return String(s).toLowerCase().trim().replace(/\\s+/g, \" \");\n}\n\n// Debug counters\nlet totalItems = items.length;\nlet foundDirectName = 0;\nlet foundInOpportunitiesArray = 0;\nlet foundInDataArray = 0;\n\n// 1) Case: items are individual opportunities\nfor (const item of items) {\n  if (item?.json?.name) {\n    contactedNames.add(norm(item.json.name));\n    foundDirectName++;\n  }\n}\n\n// 2) Case: single item contains opportunities: [...]\nfor (const item of items) {\n  const opps = item?.json?.opportunities;\n  if (Array.isArray(opps)) {\n    for (const opp of opps) {\n      if (opp?.name) {\n        contactedNames.add(norm(opp.name));\n        foundInOpportunitiesArray++;\n      }\n    }\n  }\n}\n\n// 3) Case: single item contains data: [...]\nfor (const item of items) {\n  const data = item?.json?.data;\n  if (Array.isArray(data)) {\n    for (const opp of data) {\n      if (opp?.name) {\n        contactedNames.add(norm(opp.name));\n        foundInDataArray++;\n      }\n    }\n  }\n}\n\n// Remove empty strings just in case\ncontactedNames.delete(\"\");\n\nreturn [\n  {\n    json: {\n      contactedNames: Array.from(contactedNames),\n      contactedCount: contactedNames.size\n\n      }\n    }\n];\n"
      },
